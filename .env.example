NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Supabase auth + SSR become active when these are set.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Stripe Checkout + webhook handling for packs and memberships.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Twilio WhatsApp turns on live operator messaging. Without these, Sideout logs sends but does not deliver them.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
